/node_modules
/vendor
/dist
/fonts
/favicons
/img
/compiled
/.idea
/.vscode
/mix-manifest.json


# Environment files
.env
.env.local

# Generated config files (project-specific, created by setup script)
/config/plugins-to-install.php
/config/setup-options.php
/config/acf-options.php
/config/acf-options.php.processed

# ignore all files starting with . or ~
.*
~*

# ignore node dependency directories (used by grunt)
node_modules/

# ignore OS generated files
ehthumbs.db
Thumbs.db

# ignore Editor files
*.sublime-project
*.sublime-workspace
*.komodoproject
*.vscode

# ignore log files and databases
*.log
*.sql
*.sqlite

# Playwright test artifacts
/test-results/
/playwright-report/
/playwright/.cache/

# ignore compiled files
*.com
*.class
*.dll
*.exe
*.o
*.so

# ignore packaged files
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# -------------------------
# BEGIN Whitelisted Files
# -------------------------

# track these files, if they exist
!.gitignore
!.gitattributes
!.nvmrc
!.github/
!.editorconfig
!.husky/
!.phpcs.xml.dist
!.prettierrc
!.env.example
!.releaserc.json

# track test fixtures
!tests/fixtures/.env
!tests/fixtures/dist/
!tests/fixtures/dist/.vite/
!tests/fixtures/dist/.vite/manifest.json

!README.md
!CHANGELOG.md
!composer.json
!robots.txt
!playwright.config.ts

# track favicon files, if they exist
!android-chrome-*.png
!apple-touch-icon*.png
!browserconfig.xml
!favicon*.png
!favicon*.ico
!manifest.json
!mstile-*.png
!safari-pinned-tab.svg
!site.webmanifest