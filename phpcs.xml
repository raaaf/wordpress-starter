<?xml version="1.0"?>
<ruleset name="WordPress Starter Theme">
    <description>WordPress Starter Theme Coding Standards - PSR-4 Compatible</description>

    <!-- Scan these files -->
    <file>./src</file>
    <file>./config</file>

    <!-- Ignore vendor, compiled files, and Blade templates -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/compiled/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*.blade.php</exclude-pattern>

    <!-- PHP version -->
    <config name="minimum_supported_wp_version" value="6.0"/>
    <config name="testVersion" value="8.2-"/>

    <!-- Use WordPress coding standards with PSR-4/PSR-12 exclusions -->
    <rule ref="WordPress">
        <!-- Allow short array syntax (modern PHP) -->
        <exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
        <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>

        <!-- Allow short ternary (null coalescing) -->
        <exclude name="Universal.Operators.DisallowShortTernary"/>

        <!-- PSR-4: Allow PascalCase class names and filenames -->
        <exclude name="WordPress.Files.FileName"/>

        <!-- PSR-4: Allow camelCase method names -->
        <exclude name="WordPress.NamingConventions.ValidFunctionName"/>

        <!-- PSR-4: Allow camelCase variables and properties -->
        <exclude name="WordPress.NamingConventions.ValidVariableName"/>

        <!-- PSR-12: Allow spaces for indentation -->
        <exclude name="Generic.WhiteSpace.DisallowSpaceIndent"/>

        <!-- PSR-12: Allow opening brace on new line -->
        <exclude name="Generic.Functions.OpeningFunctionBraceKernighanRitchie"/>
        <exclude name="Generic.Classes.OpeningBraceSameLine"/>
        <exclude name="WordPress.WhiteSpace.ControlStructureSpacing.OpenBraceNotSameLine"/>

        <!-- Allow Yoda conditions to be optional -->
        <exclude name="WordPress.PHP.YodaConditions"/>

        <!-- Allow inline comments without punctuation -->
        <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>

        <!-- Allow missing doc comments (use PHPStan for type checking) -->
        <exclude name="Squiz.Commenting.FileComment"/>
        <exclude name="Squiz.Commenting.ClassComment"/>
        <exclude name="Squiz.Commenting.FunctionComment"/>
        <exclude name="Squiz.Commenting.VariableComment"/>
        <exclude name="Generic.Commenting.DocComment.MissingShort"/>

        <!-- PSR-12: Allow no spaces inside parentheses -->
        <exclude name="WordPress.WhiteSpace.ControlStructureSpacing"/>
        <exclude name="PEAR.Functions.FunctionCallSignature"/>
        <exclude name="Squiz.Functions.FunctionDeclarationArgumentSpacing"/>
        <exclude name="Generic.Functions.FunctionCallArgumentSpacing"/>

        <!-- PSR-12: Allow no spaces in arrays -->
        <exclude name="WordPress.Arrays.ArrayDeclarationSpacing"/>
        <exclude name="WordPress.Arrays.ArrayKeySpacingRestrictions"/>
        <exclude name="NormalizedArrays.Arrays.ArrayBraceSpacing"/>
        <exclude name="WordPress.Arrays.MultipleStatementAlignment"/>

        <!-- Allow PSR-12 operator spacing -->
        <exclude name="WordPress.WhiteSpace.OperatorSpacing"/>
        <exclude name="Squiz.WhiteSpace.LogicalOperatorSpacing"/>

        <!-- Allow PSR-12 equals alignment (no alignment) -->
        <exclude name="Generic.Formatting.MultipleStatementAlignment"/>

        <!-- PSR-1: Classes must be in a namespace -->
        <exclude name="PSR1.Classes.ClassDeclaration.MissingNamespace"/>

        <!-- Vite handles versioning -->
        <exclude name="WordPress.WP.EnqueuedResourceParameters"/>

        <!-- Allow direct filesystem operations in theme code -->
        <exclude name="WordPress.WP.AlternativeFunctions"/>

        <!-- Allow error suppression for fsockopen -->
        <exclude name="WordPress.PHP.NoSilencedErrors"/>

        <!-- Allow trailing whitespace (handled by editor) -->
        <exclude name="Squiz.WhiteSpace.SuperfluousWhitespace"/>

        <!-- Allow common parameter names like $default, $class -->
        <exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames"/>

        <!-- Allow unused method parameters (often required by interfaces/hooks) -->
        <exclude name="Generic.CodeAnalysis.UnusedFunctionParameter"/>

        <!-- Allow debug logging in development -->
        <exclude name="WordPress.PHP.DevelopmentFunctions"/>

        <!-- Allow base64 for CSP nonces -->
        <exclude name="WordPress.PHP.DiscouragedPHPFunctions"/>
    </rule>

    <!-- Require newline at end of file -->
    <rule ref="Generic.Files.EndFileNewline"/>

    <!-- WordPress security checks (important to keep!) -->
    <rule ref="WordPress.Security"/>
    <rule ref="WordPress.DB"/>
</ruleset>