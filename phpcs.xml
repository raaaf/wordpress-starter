<?xml version="1.0"?>
<ruleset name="WordPress Starter Theme">
    <description>WordPress Starter Theme Coding Standards</description>

    <!-- Scan these files -->
    <file>./src</file>
    <file>./config</file>
    <file>./blocks</file>

    <!-- Ignore vendor and compiled files -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/compiled/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <!-- Use WordPress coding standards -->
    <rule ref="WordPress">
        <!-- Allow short array syntax -->
        <exclude name="Generic.Arrays.DisallowShortArraySyntax.Found"/>
        
        <!-- Allow modern PHP features -->
        <exclude name="WordPress.PHP.DisallowShortTernary.Found"/>
    </rule>

    <!-- Use PSR-4 autoloading standards -->
    <rule ref="PSR1.Classes.ClassDeclaration.MissingNamespace">
        <exclude-pattern>*/config/*</exclude-pattern>
    </rule>

    <!-- Enforce type hints -->
    <rule ref="SlevomatCodingStandard.TypeHints.ReturnTypeHint"/>
    <rule ref="SlevomatCodingStandard.TypeHints.ParameterTypeHint"/>
    <rule ref="SlevomatCodingStandard.TypeHints.PropertyTypeHint"/>

    <!-- PHP version -->
    <config name="minimum_supported_wp_version" value="6.0"/>
    <config name="testVersion" value="8.2-"/>
</ruleset>