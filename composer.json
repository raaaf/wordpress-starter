{
    "name": "raaaf/starter",
    "description": "A WordPress theme implementing Tailwind CSS and Alpine JS, and removing jQuery once and for all.",
    "type": "wordpress-theme",
    "license": "MIT",
    "authors": [
        {
            "name": "Rafael Alex",
            "email": "a@rafaelalex.de"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/view": "^12.0",
        "illuminate/events": "^12.0",
        "illuminate/filesystem": "^12.0",
        "illuminate/support": "^12.0",
        "illuminate/container": "^12.0"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.13",
        "wp-coding-standards/wpcs": "^3.1",
        "phpstan/phpstan": "^2.1",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.92",
        "phpoption/phpoption": "^1.9",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "WordpressStarter\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "npm install",
            "@phpcs-config"
        ],
        "post-update-cmd": [
            "@phpcs-config"
        ],
        "test": "phpunit",
        "phpcs": "phpcs",
        "phpcs:fix": "phpcbf",
        "phpstan": "phpstan analyze",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "lint": [
            "@phpcs",
            "@phpstan"
        ],
        "phpcs-config": "phpcs --config-set installed_paths vendor/wp-coding-standards/wpcs"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
