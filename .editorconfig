# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,ts,jsx,tsx,json,css,scss,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.blade.php]
indent_size = 4

[Makefile]
indent_style = tab
