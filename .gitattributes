# Auto detect text files and perform LF normalization
* text=auto

# PHP files
*.php text eol=lf

# JavaScript/TypeScript
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.json text eol=lf

# CSS
*.css text eol=lf
*.scss text eol=lf

# Templates
*.blade.php text eol=lf
*.html text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.env text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
.nvmrc text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
LICENSE text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary files - do not normalize
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.gz binary

# Vendored files - do not diff
vendor/** linguist-vendored
node_modules/** linguist-vendored
dist/** linguist-generated

# Lock files - do not diff
package-lock.json binary
composer.lock binary
