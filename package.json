{
	"name": "wp-starter",
	"version": "0.0.1",
	"type": "module",
	"description": "Wordpress-Starter-Theme based on Tailpress and MountainBreeze",
	"author": "Rafael Alex",
	"repository": {
		"type": "git",
		"url": "https://github.com/raaaf/starter"
	},
	"theme_uri": "https://github.com/raaaf/starter",
	"author_uri": "https://rafaelalex.de",
	"text_domain": "wp-starter",
	"license": "GPL-2.0",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"analyze": "vite build --mode analyze",
		"lint": "eslint resources/js",
		"lint:fix": "eslint resources/js --fix",
		"format": "prettier --write \"resources/**/*.{js,ts,css,json}\"",
		"prepare": "husky"
	},
	"devDependencies": {
		"@eslint/js": "^9.18.0",
		"@tailwindcss/postcss": "^4.1.18",
		"@types/alpinejs": "^3.13.11",
		"@types/wordpress__blocks": "^12.5.18",
		"@vitejs/plugin-legacy": "^7.2.1",
		"autoprefixer": "^10.4.23",
		"cssnano": "^7.0.6",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-prettier": "^5.5.5",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"postcss": "^8.5.3",
		"prettier": "^3.8.0",
		"rollup-plugin-visualizer": "^6.0.5",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.21.0",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"alpinejs": "^3.15.3"
	},
	"lint-staged": {
		"*.{js,ts}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{css,json,md}": [
			"prettier --write"
		],
		"*.php": [
			"php -l"
		]
	}
}
