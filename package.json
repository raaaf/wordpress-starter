		"hot": "mix watch --hot",
		"production": "mix --production"
	},
	"devDependencies": {
		"autoprefixer": "^10.4.20",
		"browser-sync": "^3.0.3",
		"browser-sync-webpack-plugin": "^2.3.0",
		"cross-env": "^7.0.3",
		"laravel-mix": "^6.0.49",
		"postcss": "^8.5.3",
		"postcss-import": "^16.1.0",
		"postcss-nested": "^7.0.2",
		"postcss-nested-ancestors": "^3.0.0",
		"resolve-url-loader": "^5.0.0",
		"tailwindcss": "^4.0.8"
	}
