{
  "name": "wp-starter",
  "version": "2.12.0",
  "type": "module",
  "description": "Wordpress-Starter-Theme based on Tailpress and MountainBreeze",
  "author": "Rafael Alex",
  "repository": {
    "type": "git",
    "url": "https://github.com/raaaf/starter"
  },
  "theme_uri": "https://github.com/raaaf/starter",
  "author_uri": "https://rafaelalex.de",
  "text_domain": "wp-starter",
  "license": "GPL-2.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "analyze": "vite build --mode analyze",
    "tokens": "node scripts/transform-tokens.js",
    "tokens:watch": "node --watch scripts/transform-tokens.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "lint": "eslint resources/js",
    "lint:fix": "eslint resources/js --fix",
    "format": "prettier --write \"resources/**/*.{js,ts,css,json}\"",
    "prepare": "husky",
    "package": "npm run build && node scripts/package-theme.js"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.50.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@types/alpinejs": "^3.13.11",
    "@types/wordpress__blocks": "^12.5.18",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "archiver": "^7.0.1",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "cssnano": "^7.0.6",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "happy-dom": "^20.3.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.3",
    "prettier": "^3.8.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "semantic-release": "^25.0.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.21.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.4",
    "@alpinejs/intersect": "^3.15.4",
    "alpinejs": "^3.15.3",
    "medium-zoom": "^1.1.0"
  },
  "lint-staged": {
    "resources/js/**/*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ],
    "*.php": [
      "php -l"
    ]
  }
}
