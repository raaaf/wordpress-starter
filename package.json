{
	"name": "wp-starter",
	"version": "0.0.1",
	"description": "Wordpress-Starter-Theme based on Tailpress and MountainBreeze",
	"author": "Rafael Alex",
	"repository": {
		"type": "git",
		"url": "https://github.com/raaaf/starter"
	},
	"theme_uri": "https://github.com/raaaf/starter",
	"author_uri": "https://rafaelalex.de",
	"text_domain": "wp-starter",
	"license": "GPL-2.0",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"analyze": "vite build --mode analyze",
		"lint": "eslint resources/js --ext .js,.ts",
		"lint:fix": "eslint resources/js --ext .js,.ts --fix",
		"format": "prettier --write \"resources/**/*.{js,ts,css,json}\"",
		"prepare": "husky install"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.0.8",
		"@types/alpinejs": "^3.13.10",
		"@types/wordpress__blocks": "^12.5.14",
		"@typescript-eslint/eslint-plugin": "^7.1.0",
		"@typescript-eslint/parser": "^7.1.0",
		"@vitejs/plugin-legacy": "^6.0.0",
		"autoprefixer": "^10.4.20",
		"cssnano": "^6.0.0",
		"eslint": "^8.57.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.1.3",
		"husky": "^9.0.11",
		"lint-staged": "^15.2.2",
		"postcss": "^8.5.3",
		"prettier": "^3.2.5",
		"rollup-plugin-visualizer": "^5.12.0",
		"tailwindcss": "^4.0.8",
		"typescript": "^5.4.0",
		"vite": "^7.0.0",
		"vite-plugin-compression": "^0.5.1",
		"vite-plugin-imagemin": "^0.6.1"
	},
	"dependencies": {
		"alpinejs": "^3.14.9"
	},
	"lint-staged": {
		"*.{js,ts}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{css,json,md}": [
			"prettier --write"
		],
		"*.php": [
			"php -l"
		]
	}
}
