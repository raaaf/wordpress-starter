{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "custom": true,
      "customDuotone": true,
      "customGradient": true,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "duotone": [],
      "gradients": [],
      "link": true,
      "palette": [
        {
          "slug": "primary",
          "color": "oklch(0.72 0.11 178)",
          "name": "Primary"
        },
        {
          "slug": "secondary",
          "color": "#6B7280",
          "name": "Secondary"
        },
        {
          "slug": "background",
          "color": "#FFFFFF",
          "name": "Background"
        },
        {
          "slug": "foreground",
          "color": "#111827",
          "name": "Foreground"
        }
      ]
    },
    "typography": {
      "customFontSize": true,
      "dropCap": false,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "\"Lato\", ui-sans-serif, system-ui, sans-serif",
          "slug": "sans",
          "name": "Sans Serif"
        },
        {
          "fontFamily": "ui-serif, Georgia, Cambria, \"Times New Roman\", Times, serif",
          "slug": "serif",
          "name": "Serif"
        },
        {
          "fontFamily": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace",
          "slug": "mono",
          "name": "Monospace"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "size": "0.875rem",
          "name": "Small",
          "fluid": {
            "min": "0.875rem",
            "max": "1rem"
          }
        },
        {
          "slug": "medium",
          "size": "1rem",
          "name": "Medium",
          "fluid": {
            "min": "1rem",
            "max": "1.125rem"
          }
        },
        {
          "slug": "large",
          "size": "1.25rem",
          "name": "Large",
          "fluid": {
            "min": "1.125rem",
            "max": "1.5rem"
          }
        },
        {
          "slug": "x-large",
          "size": "1.5rem",
          "name": "Extra Large",
          "fluid": {
            "min": "1.25rem",
            "max": "2rem"
          }
        },
        {
          "slug": "xx-large",
          "size": "2.25rem",
          "name": "2X Large",
          "fluid": {
            "min": "1.75rem",
            "max": "3rem"
          }
        }
      ]
    },
    "spacing": {
      "spacingScale": {
        "steps": 0
      },
      "spacingSizes": [
        {
          "slug": "10",
          "size": "0.25rem",
          "name": "10"
        },
        {
          "slug": "20",
          "size": "0.5rem",
          "name": "20"
        },
        {
          "slug": "30",
          "size": "1rem",
          "name": "30"
        },
        {
          "slug": "40",
          "size": "1.5rem",
          "name": "40"
        },
        {
          "slug": "50",
          "size": "2rem",
          "name": "50"
        },
        {
          "slug": "60",
          "size": "3rem",
          "name": "60"
        },
        {
          "slug": "70",
          "size": "4rem",
          "name": "70"
        },
        {
          "slug": "80",
          "size": "6rem",
          "name": "80"
        }
      ],
      "units": ["%", "px", "em", "rem", "vh", "vw"]
    },
    "layout": {
      "contentSize": "42rem",
      "wideSize": "64rem"
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "dimensions": {
      "minHeight": true
    },
    "position": {
      "sticky": true
    },
    "shadow": {
      "presets": [
        {
          "name": "Small",
          "slug": "small",
          "shadow": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "shadow": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)"
        },
        {
          "name": "Large",
          "slug": "large",
          "shadow": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)"
        }
      ]
    },
    "custom": {
      "spacing": {},
      "typography": {
        "line-height": {
          "body": 1.5,
          "heading": 1.2
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--foreground)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.5"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--30)",
      "padding": {
        "left": "var(--wp--preset--spacing--30)",
        "right": "var(--wp--preset--spacing--30)"
      }
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--secondary)"
          }
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xx-large)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "fontWeight": "700",
          "lineHeight": "1.3"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--large)",
          "fontWeight": "600",
          "lineHeight": "1.4"
        }
      }
    },
    "blocks": {
      "core/paragraph": {
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "var(--wp--preset--spacing--30)"
          }
        }
      },
      "core/heading": {
        "spacing": {
          "margin": {
            "top": "var(--wp--preset--spacing--40)",
            "bottom": "var(--wp--preset--spacing--20)"
          }
        }
      }
    }
  },
  "customTemplates": [],
  "templateParts": []
}