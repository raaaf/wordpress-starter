{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "custom": true,
      "customDuotone": true,
      "customGradient": true,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "duotone": [],
      "link": true,
      "palette": [
        {
          "slug": "primary",
          "color": "var(--bg-primary, #FFFFFF)",
          "name": "Standard (Weiß)"
        },
        {
          "slug": "secondary",
          "color": "var(--bg-secondary, #FAFAFA)",
          "name": "Sekundär (Hellgrau)"
        },
        {
          "slug": "tertiary",
          "color": "var(--bg-tertiary, #F5F5F5)",
          "name": "Tertiär"
        },
        {
          "slug": "brand",
          "color": "var(--bg-brand, #FF6B35)",
          "name": "Markenfarbe"
        },
        {
          "slug": "brand-subtle",
          "color": "var(--bg-brand-subtle, #FFF4F0)",
          "name": "Markenfarbe Dezent"
        },
        {
          "slug": "inverse",
          "color": "var(--bg-inverse, #171717)",
          "name": "Dunkel (Invers)"
        },
        {
          "slug": "accent",
          "color": "var(--bg-accent, #FF6B35)",
          "name": "Akzent"
        },
        {
          "slug": "accent-subtle",
          "color": "var(--bg-accent-subtle, #FFF4F0)",
          "name": "Akzent Dezent"
        },
        {
          "slug": "success",
          "color": "var(--bg-success, #DCFCE7)",
          "name": "Erfolg"
        },
        {
          "slug": "warning",
          "color": "var(--bg-warning, #FEF3C7)",
          "name": "Warnung"
        },
        {
          "slug": "error",
          "color": "var(--bg-error, #FEE2E2)",
          "name": "Fehler"
        },
        {
          "slug": "text-primary",
          "color": "var(--text-primary, #171717)",
          "name": "Text Primär"
        },
        {
          "slug": "text-secondary",
          "color": "var(--text-secondary, #525252)",
          "name": "Text Sekundär"
        },
        {
          "slug": "text-inverse",
          "color": "var(--text-inverse, #FFFFFF)",
          "name": "Text Invers"
        },
        {
          "slug": "text-brand",
          "color": "var(--text-brand, #E5541D)",
          "name": "Text Markenfarbe"
        }
      ],
      "gradients": [
        {
          "slug": "brand-gradient",
          "gradient": "linear-gradient(135deg, var(--bg-brand, #FF6B35) 0%, var(--bg-brand-hover, #E5541D) 100%)",
          "name": "Markenfarbe Verlauf"
        },
        {
          "slug": "dark-gradient",
          "gradient": "linear-gradient(180deg, var(--bg-inverse, #171717) 0%, var(--color-gray-800, #262626) 100%)",
          "name": "Dunkel Verlauf"
        }
      ]
    },
    "typography": {
      "customFontSize": true,
      "dropCap": false,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "var(--font-family-body, Inter), ui-sans-serif, system-ui, sans-serif",
          "slug": "body",
          "name": "Body (Inter)"
        },
        {
          "fontFamily": "var(--font-family-headline, ColaborateLight), ui-sans-serif, system-ui, sans-serif",
          "slug": "headline",
          "name": "Headline"
        },
        {
          "fontFamily": "var(--font-family-mono, 'JetBrains Mono'), ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
          "slug": "mono",
          "name": "Monospace"
        }
      ],
      "fontSizes": [
        {
          "slug": "caption",
          "size": "var(--typography-caption-size, 0.75rem)",
          "name": "Caption (12px)"
        },
        {
          "slug": "body-small",
          "size": "var(--typography-body-small-size, 0.875rem)",
          "name": "Body Small (14px)"
        },
        {
          "slug": "body",
          "size": "var(--typography-body-size, 1rem)",
          "name": "Body (16px)"
        },
        {
          "slug": "body-large",
          "size": "var(--typography-body-large-size, 1.125rem)",
          "name": "Body Large (18px)"
        },
        {
          "slug": "h5",
          "size": "var(--typography-h5-size, 1.125rem)",
          "name": "Heading 5 (18px)"
        },
        {
          "slug": "h4",
          "size": "var(--typography-h4-size, 1.25rem)",
          "name": "Heading 4 (20px)"
        },
        {
          "slug": "h3",
          "size": "var(--typography-h3-size, 1.5rem)",
          "name": "Heading 3 (24px)"
        },
        {
          "slug": "h2",
          "size": "var(--typography-h2-size, 1.875rem)",
          "name": "Heading 2 (30px)"
        },
        {
          "slug": "h1",
          "size": "var(--typography-h1-size, 2.25rem)",
          "name": "Heading 1 (36px)"
        },
        {
          "slug": "display",
          "size": "var(--typography-display-size, 3.75rem)",
          "name": "Display (60px)"
        }
      ],
      "fontWeights": [
        {
          "slug": "regular",
          "value": "var(--font-weight-regular, 400)",
          "name": "Regular"
        },
        {
          "slug": "medium",
          "value": "var(--font-weight-medium, 500)",
          "name": "Medium"
        },
        {
          "slug": "semibold",
          "value": "var(--font-weight-semibold, 600)",
          "name": "Semibold"
        },
        {
          "slug": "bold",
          "value": "var(--font-weight-bold, 700)",
          "name": "Bold"
        }
      ]
    },
    "spacing": {
      "spacingScale": {
        "steps": 0
      },
      "spacingSizes": [
        {
          "slug": "0-5",
          "size": "var(--spacing-0-5, 2px)",
          "name": "0.5 (2px)"
        },
        {
          "slug": "1-5",
          "size": "var(--spacing-1-5, 6px)",
          "name": "1.5 (6px)"
        },
        {
          "slug": "2-5",
          "size": "var(--spacing-2-5, 10px)",
          "name": "2.5 (10px)"
        },
        {
          "slug": "3",
          "size": "var(--spacing-3, 12px)",
          "name": "3 (12px)"
        },
        {
          "slug": "4",
          "size": "var(--spacing-4, 16px)",
          "name": "4 (16px)"
        },
        {
          "slug": "5",
          "size": "var(--spacing-5, 20px)",
          "name": "5 (20px)"
        },
        {
          "slug": "6",
          "size": "var(--spacing-6, 24px)",
          "name": "6 (24px)"
        },
        {
          "slug": "8",
          "size": "var(--spacing-8, 32px)",
          "name": "8 (32px)"
        },
        {
          "slug": "10",
          "size": "var(--spacing-10, 40px)",
          "name": "10 (40px)"
        },
        {
          "slug": "12",
          "size": "var(--spacing-12, 48px)",
          "name": "12 (48px)"
        },
        {
          "slug": "16",
          "size": "var(--spacing-16, 64px)",
          "name": "16 (64px)"
        },
        {
          "slug": "20",
          "size": "var(--spacing-20, 80px)",
          "name": "20 (80px)"
        },
        {
          "slug": "24",
          "size": "var(--spacing-24, 96px)",
          "name": "24 (96px)"
        }
      ],
      "units": ["%", "px", "em", "rem", "vh", "vw"]
    },
    "layout": {
      "contentSize": "42rem",
      "wideSize": "64rem"
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "dimensions": {
      "minHeight": true
    },
    "position": {
      "sticky": true
    },
    "shadow": {
      "presets": [
        {
          "name": "Small",
          "slug": "sm",
          "shadow": "0 1px 2px 0 rgb(0 0 0 / 0.05)"
        },
        {
          "name": "Default",
          "slug": "default",
          "shadow": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)"
        },
        {
          "name": "Medium",
          "slug": "md",
          "shadow": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)"
        },
        {
          "name": "Large",
          "slug": "lg",
          "shadow": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)"
        },
        {
          "name": "Extra Large",
          "slug": "xl",
          "shadow": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)"
        },
        {
          "name": "2X Large",
          "slug": "2xl",
          "shadow": "0 25px 50px -12px rgb(0 0 0 / 0.25)"
        }
      ]
    },
    "custom": {
      "border-radius": {
        "none": "var(--radius-none, 0px)",
        "sm": "var(--radius-sm, 4px)",
        "default": "var(--radius-default, 6px)",
        "md": "var(--radius-md, 8px)",
        "lg": "var(--radius-lg, 12px)",
        "xl": "var(--radius-xl, 16px)",
        "2xl": "var(--radius-2xl, 20px)",
        "3xl": "var(--radius-3xl, 24px)",
        "full": "var(--radius-full, 9999px)"
      },
      "typography": {
        "line-height": {
          "body": 1.5,
          "heading": 1.2
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--bg-primary, #FFFFFF)",
      "text": "var(--text-primary, #171717)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.5"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--4)",
      "padding": {
        "left": "var(--wp--preset--spacing--4)",
        "right": "var(--wp--preset--spacing--4)"
      }
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--text-link, #E5541D)"
        },
        ":hover": {
          "color": {
            "text": "var(--text-link-hover, #C43D0A)"
          }
        }
      },
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--headline)",
          "fontSize": "var(--typography-h1-size, 2.25rem)",
          "fontWeight": "var(--typography-h1-weight, 700)",
          "lineHeight": "var(--typography-h1-line-height, 1.2)",
          "letterSpacing": "var(--typography-h1-letter-spacing, -0.01em)"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--headline)",
          "fontSize": "var(--typography-h2-size, 1.875rem)",
          "fontWeight": "var(--typography-h2-weight, 600)",
          "lineHeight": "var(--typography-h2-line-height, 1.25)",
          "letterSpacing": "var(--typography-h2-letter-spacing, -0.01em)"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--headline)",
          "fontSize": "var(--typography-h3-size, 1.5rem)",
          "fontWeight": "var(--typography-h3-weight, 600)",
          "lineHeight": "var(--typography-h3-line-height, 1.3)"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--typography-h4-size, 1.25rem)",
          "fontWeight": "var(--typography-h4-weight, 600)",
          "lineHeight": "var(--typography-h4-line-height, 1.4)"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "var(--typography-h5-size, 1.125rem)",
          "fontWeight": "var(--typography-h5-weight, 500)",
          "lineHeight": "var(--typography-h5-line-height, 1.4)"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "var(--typography-body-large-size, 1.125rem)",
          "fontWeight": "var(--typography-body-large-weight, 400)",
          "lineHeight": "var(--typography-body-large-line-height, 1.6)"
        }
      },
      "caption": {
        "typography": {
          "fontSize": "var(--typography-caption-size, 0.75rem)",
          "fontWeight": "var(--typography-caption-weight, 400)",
          "lineHeight": "var(--typography-caption-line-height, 1.4)"
        }
      },
      "button": {
        "border": {
          "radius": "var(--radius-default, 6px)"
        },
        "color": {
          "background": "var(--bg-brand, #FF6B35)",
          "text": "var(--text-on-color, #FFFFFF)"
        },
        ":hover": {
          "color": {
            "background": "var(--bg-brand-hover, #E5541D)"
          }
        }
      }
    },
    "blocks": {
      "core/paragraph": {
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "var(--wp--preset--spacing--4)"
          }
        }
      },
      "core/heading": {
        "spacing": {
          "margin": {
            "top": "var(--wp--preset--spacing--6)",
            "bottom": "var(--wp--preset--spacing--3)"
          }
        }
      },
      "core/button": {
        "border": {
          "radius": "var(--radius-default, 6px)"
        }
      },
      "core/image": {
        "border": {
          "radius": "var(--radius-md, 8px)"
        }
      }
    }
  },
  "customTemplates": [],
  "templateParts": []
}